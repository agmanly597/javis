<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        For a pure Jetpack Compose app, we use the Android framework theme
        android:Theme.DeviceDefault.NoActionBar — no extra library dependency needed.
        All visual styling is done in Compose via MaterialTheme; this XML theme
        is only used for the initial window decoration.
    -->
    <style name="Theme.JAVIS" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>
</resources>
